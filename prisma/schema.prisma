generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/bot_data.db"
}

model Schedule {
  id        Int      @id @default(autoincrement())
  task_id   String
  time      DateTime
  recurring String?
  // JSON.stringified data
  data      String?

  @@map("schedules")
}

// ACTUAL MODELS FOR THE FEATURES OF THIS BOT //

model MessageOnlyChannel {
  channel_id String @id
  guild_id   String

  @@map("message_only_channels")
}

model SharedGuildBan {
  user_id  String  @id
  guild_id String
  reason   String?

  @@map("shared_guild_bans")
}

model AutoPin {
  id                  String   @id @default(cuid())
  content             String
  channel_id          String
  guild_id            String
  check_every_seconds BigInt
  last_check          DateTime
  last_message_id     String?

  @@map("auto_pins")
}
